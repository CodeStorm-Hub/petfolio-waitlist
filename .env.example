# Copy to `.env` and fill in real values (`.env` is gitignored).

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_anon_jwt

ZOHO_MAIL_ADDRESS=welcome@yourdomain.com
ZOHO_MAIL_PASSWORD=

# Optional — defaults: smtp.zoho.com, port 465 (SSL). Use 587 for STARTTLS.
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=465

# Optional
# ZOHO_MAIL_REPLY_TO=support@yourdomain.com
# PETFOLIO_UNSUBSCRIBE_URL=https://petfolio.social/unsubscribe
